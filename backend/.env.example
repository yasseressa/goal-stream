APP_NAME=Melbet Live API
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
LOG_LEVEL=INFO
LOG_JSON=false
SPORTS_PROVIDER=mock
NEWS_PROVIDER=mock
CACHE_DEFAULT_TTL_SECONDS=300
CACHE_REDIRECT_CONFIG_TTL_SECONDS=30

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=melbet_live
DATABASE_USER=melbet
DATABASE_PASSWORD=melbet
